# Environment Variables Template for Ravan AI

# --- Backend Config (FastAPI) ---
# Database
DATABASE_URL=postgresql://ravan_admin:ravan_password@localhost:5432/ravan_ai
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Vector Database
CHROMA_URL=http://localhost:8000

# AI Model APIs
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GEMINI_API_KEY=AIzaSy-your-gemini-key
DEEPSEEK_API_KEY=sk-your-deepseek-key
DASHSCOPE_API_KEY=sk-your-dashscope-key   # Qwen via Alibaba DashScope
QWEN_API_KEY=your-qwen-key
LLAMA_API_KEY=your-llama-key # Or local endpoint

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# --- Frontend Config (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
